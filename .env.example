# ============================================================
# WispHub API — Variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# ============================================================

# ----------------------------------------------------------
# Credenciales WispHub Net (requerido)
# ----------------------------------------------------------

# Clave API de autenticación hacia WispHub Net
WISPHUB_NET_KEY=your-wisphub-api-key

# URL base del servidor WispHub (sin barra final)
WISPHUB_NET_HOST=https://tuservidor.wisphub.net

# ----------------------------------------------------------
# Autenticación interna (requerido)
# Clave que el frontend/chatbot debe enviar en el header X-API-Key
# ----------------------------------------------------------
WISPHUB_INTERNAL_API_KEY=your-internal-secret-key

# ----------------------------------------------------------
# Tickets (opcional — valores por defecto mostrados)
# ----------------------------------------------------------

# Límite de tickets activos por zona antes de bloquear nuevos tickets
MAX_ACTIVE_TICKETS_PER_ZONE=3

# IDs de estado que se consideran "activo" en WispHub (JSON array)
ACTIVE_TICKET_STATES=[1]

# ID del estado inicial para tickets recién creados
DEFAULT_TICKET_STATUS=1

# Días hábiles máximos para resolver un ticket
MAX_TICKET_RESOLUTION_DAYS=3

# ----------------------------------------------------------
# Feriados adicionales (opcional)
# Los feriados colombianos estándar se calculan automáticamente.
# Usa EXTRA_HOLIDAYS para agregar fechas regionales, puentes
# o feriados empresariales no incluidos en el calendario oficial.
# Formato: JSON array de fechas ISO "YYYY-MM-DD"
# ----------------------------------------------------------
# EXTRA_HOLIDAYS=["2026-06-22", "2026-11-03"]

# ----------------------------------------------------------
# Proveedor ISP (opcional — no cambiar salvo nuevas integraciones)
# ----------------------------------------------------------
ISP_PROVIDER=wisphub
